{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://water.gov.il/schemas/zone-brief.schema.json",
  "title": "Industrial Zone Report Brief",
  "description": "Per-zone data contract. Feeds the report-generation engine. One YAML per zone.",
  "type": "object",
  "required": ["zone", "kpis", "family_ledger", "framing_warning", "findings", "boreholes"],
  "additionalProperties": false,

  "properties": {

    "zone": {
      "type": "object",
      "description": "Top-level identification + period metadata.",
      "required": ["id", "name_he", "period", "edition", "edition_date", "active_boreholes", "contaminant_families_count"],
      "additionalProperties": false,
      "properties": {
        "id":                    { "type": "string", "pattern": "^[A-Z]{2,8}$", "description": "Short uppercase code, e.g. HOL, ASH, BRS" },
        "name_he":               { "type": "string" },
        "name_en":               { "type": "string" },
        "period":                { "type": "string", "description": "Analysis window, e.g. '2020–2026'" },
        "edition":               { "type": "string", "description": "Edition tag, e.g. '2026-01'" },
        "edition_date":          { "type": "string", "pattern": "^\\d{4}-\\d{2}$", "description": "YYYY-MM of publication" },
        "doc_id_internal":       { "type": "string", "description": "e.g. HOL/EXEC/INT/2026-01" },
        "doc_id_public":         { "type": "string", "description": "e.g. HOL/EXEC/PUB/2026-01" },
        "active_boreholes":      { "type": ["integer", "string"], "description": "Count or placeholder like '~58'" },
        "contaminant_families_count": { "type": "integer", "minimum": 1, "maximum": 10 },
        "monitoring_gaps_count": { "type": "integer", "minimum": 0 },
        "pfas_coverage_pct":     { "type": "number", "minimum": 0, "maximum": 100 },
        "exceedance_count":      { "type": "integer", "minimum": 0 }
      }
    },

    "bottom_line": {
      "type": "array",
      "description": "INTERNAL §00 — 2 to 4 short paragraphs framing the period. Plain Hebrew prose with <bdi> wrappers around LTR tokens.",
      "items": { "type": "string" },
      "minItems": 2, "maxItems": 4
    },

    "context_intro": {
      "type": "array",
      "description": "PUBLIC §01 — 2 to 4 paragraphs of context. Serif body. First paragraph can carry a drop-cap.",
      "items": { "type": "string" },
      "minItems": 2, "maxItems": 4
    },

    "framing_warning": {
      "type": "string",
      "description": "The selection-bias caveat. Required in both reports. Wraps with amber callout."
    },

    "kpis": {
      "type": "array",
      "description": "INTERNAL §01 — typically 4 cards. Each becomes one cell in kpi-grid.",
      "items": {
        "type": "object",
        "required": ["id", "label", "value", "tier"],
        "additionalProperties": false,
        "properties": {
          "id":     { "type": "string" },
          "label":  { "type": "string" },
          "value":  { "type": "string", "description": "Numeric display value, can include unit suffix" },
          "unit":   { "type": "string" },
          "tier":   { "enum": ["neutral", "urgent", "teal", "good"] },
          "delta":  { "type": "string", "description": "Optional delta line (e.g. '▲ +101 pp')" },
          "note":   { "type": "string" },
          "spark":  { "type": "array", "items": { "type": "object", "properties": { "h": {"type":"number"}, "hi": {"type":"boolean"} } } }
        }
      },
      "minItems": 3, "maxItems": 6
    },

    "stats_public": {
      "type": "array",
      "description": "PUBLIC §01 — typically 3 stat cards (lighter than internal KPIs).",
      "items": {
        "type": "object",
        "required": ["k", "v"],
        "properties": {
          "k":      { "type": "string", "description": "Label" },
          "v":      { "type": "string", "description": "Value" },
          "tier":   { "enum": ["neutral", "red", "teal", "green"] },
          "note":   { "type": "string" }
        }
      }
    },

    "family_ledger": {
      "type": "array",
      "description": "INTERNAL §02 — one row per contaminant family.",
      "items": {
        "type": "object",
        "required": ["family", "desc", "narrative", "count_value", "count_label"],
        "properties": {
          "family":      { "type": "string", "description": "e.g. CVOC, METALS, PFAS, FUEL" },
          "desc":        { "type": "string", "description": "Hebrew long-form description" },
          "narrative":   { "type": "string" },
          "count_value": { "type": "string", "description": "e.g. '×9' or '0/2'" },
          "count_label": { "type": "string" },
          "dim":         { "type": "boolean", "description": "If true, count appears dimmed (no exceedances)" }
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Both reports §03. Typically 7 findings — but any count from 5 to 9 supported.",
      "minItems": 5, "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["id", "urgency", "title_internal", "title_public", "body_internal", "body_public"],
        "properties": {
          "id":               { "type": "string", "pattern": "^F[0-9]{1,2}$" },
          "urgency":          { "enum": ["critical", "high", "good"] },
          "title_internal":   { "type": "string" },
          "title_public":     { "type": "string" },
          "body_internal":    { "type": "string" },
          "body_public":      { "type": "string" },
          "action_internal":  { "type": "string", "description": "The 'לפעולה' callout in internal" },
          "public_what_it_means": { "type": "string" },
          "public_what_we_do":   { "type": "string" },
          "stat": {
            "type": "object",
            "description": "Optional headline stat shown in public version",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "color": { "enum": ["red", "green", "neutral"] }
            }
          },
          "metadata": {
            "type": "array",
            "description": "Aside rows in internal version",
            "items": {
              "type": "object",
              "required": ["k", "v"],
              "properties": {
                "k":     { "type": "string" },
                "v":     { "type": "string" },
                "color": { "enum": ["red", "green", "neutral"] }
              }
            }
          },
          "certainty": { "enum": ["high", "medium", "low"] }
        }
      }
    },

    "boreholes": {
      "type": "array",
      "description": "All monitoring boreholes. Used by §04 matrix (internal), §06 map (internal), §04 map (public).",
      "items": {
        "type": "object",
        "required": ["id", "name_he", "tier", "coords"],
        "properties": {
          "id":            { "type": "string", "description": "Internal stable ID, e.g. MK-14" },
          "name_he":       { "type": "string", "description": "Real Hebrew name" },
          "role":          { "type": "string", "description": "e.g. 'קידוח הפקה', 'ניטור', 'חקלאי'" },
          "tier":          { "enum": ["critical", "high", "medium", "low", "silent", "success"] },
          "coords":        { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2, "description": "[lat, lon] WGS-84" },
          "silent_months": { "type": ["integer", "null"], "description": "If silent, how many months" },
          "on_severity_matrix": { "type": "boolean", "description": "Show in §04 matrix" },
          "severity_by_family": {
            "type": "object",
            "description": "Scores 0-8 per family — used in §04 matrix cells",
            "additionalProperties": { "type": ["integer", "null"], "minimum": 0, "maximum": 8 }
          },
          "popup_rows_internal": {
            "type": "array",
            "description": "Rows in §06 internal popup",
            "items": { "$ref": "#/$defs/popup_row" }
          },
          "public": {
            "type": "object",
            "description": "Public-facing facade. NEVER includes real name.",
            "required": ["code", "desc"],
            "properties": {
              "code":        { "type": "string", "pattern": "^B-[0-9]{2,3}$", "description": "Anonymized code, e.g. B-01" },
              "desc":        { "type": "string", "description": "Generic role, e.g. 'קידוח אספקה'" },
              "tier":        { "enum": ["crit", "high", "med", "low", "silent", "success"] },
              "popup_rows":  { "type": "array", "items": { "$ref": "#/$defs/popup_row" } }
            }
          }
        }
      }
    },

    "sources": {
      "type": "array",
      "description": "Suspected pollution sources. Used in INTERNAL §06 map ONLY. NEVER rendered in PUBLIC.",
      "items": {
        "type": "object",
        "required": ["id", "name_internal", "certainty", "coords"],
        "properties": {
          "id":             { "type": "string" },
          "name_internal":  { "type": "string", "description": "Real name — internal only" },
          "name_generic":   { "type": "string", "description": "Generic category — for documentation only, never rendered" },
          "certainty":      { "enum": ["high", "medium", "low"] },
          "category":       { "type": "string", "description": "e.g. 'מפעל ציפוי מתכות'" },
          "contaminants":   { "type": "array", "items": { "type": "string" } },
          "status":         { "type": "string", "description": "e.g. 'פעיל', 'סגור', 'משוקם'" },
          "coords":         { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
        }
      }
    },

    "plume_paths": {
      "type": "array",
      "description": "Polylines on the map (e.g. dioxane plume direction).",
      "items": {
        "type": "object",
        "required": ["path", "label"],
        "properties": {
          "path":  { "type": "array", "items": { "type": "array", "items": {"type":"number"}, "minItems":2, "maxItems":2 }, "minItems": 2 },
          "label": { "type": "string" },
          "color": { "enum": ["red", "teal"], "default": "red" }
        }
      }
    },

    "decisions": {
      "type": "array",
      "description": "INTERNAL §05 — grouped by category. ONE entry per category.",
      "items": {
        "type": "object",
        "required": ["category", "actions"],
        "properties": {
          "category": { "type": "string" },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["action", "need"],
              "properties": {
                "action":       { "type": "string", "description": "Short imperative" },
                "need":         { "type": "string", "description": "One-sentence elaboration" },
                "notes":        { "type": "string", "description": "Mono-styled note, e.g. 'F·01 | חריגה 101%'" },
                "finding_refs": { "type": "array", "items": { "type": "string", "pattern": "^F[0-9]{1,2}$" } }
              }
            }
          }
        }
      }
    },

    "timeline": {
      "type": "array",
      "description": "PUBLIC §02 — narrative events. Typically 6–8.",
      "items": {
        "type": "object",
        "required": ["id", "period", "type", "label", "text", "position_pct", "layer"],
        "properties": {
          "id":           { "type": "string" },
          "period":       { "type": "string", "description": "e.g. '1965–85', '04/2025'" },
          "type":         { "enum": ["hist", "crit", "good", "cur"] },
          "label":        { "type": "string", "description": "Short headline (3–6 words)" },
          "text":         { "type": "string", "description": "1 sentence" },
          "position_pct": { "type": "number", "minimum": 0, "maximum": 100, "description": "Position along left-to-right axis as %" },
          "layer":        { "enum": ["A", "B", "C", "D"], "description": "Vertical layer to avoid card overlap" },
          "edge":         { "enum": ["left", "right", null], "description": "Edge alignment for extreme positions" }
        }
      }
    },

    "means_summary": {
      "type": "array",
      "description": "PUBLIC §05 — 'what it means · what we do'. Typically 4 cards.",
      "items": {
        "type": "object",
        "required": ["label", "title", "body"],
        "properties": {
          "label":  { "type": "string", "description": "Mono eyebrow, e.g. 'סיכום · א'" },
          "title":  { "type": "string" },
          "body":   { "type": "string", "description": "Prose. May contain <ul><li> for bullet lists." }
        }
      }
    },

    "methodology": {
      "type": "array",
      "description": "PUBLIC §06 — 3 short cells explaining how the report was made.",
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string" },
          "body":  { "type": "string" }
        }
      },
      "minItems": 2, "maxItems": 4
    },

    "contact": {
      "type": "object",
      "description": "PUBLIC footer.",
      "properties": {
        "email":         { "type": "string", "format": "email" },
        "raw_data_note": { "type": "string" }
      }
    }
  },

  "$defs": {
    "popup_row": {
      "type": "object",
      "required": ["k", "v"],
      "properties": {
        "k":     { "type": "string" },
        "v":     { "type": "string" },
        "color": { "enum": ["red", "green", "neutral"] }
      }
    }
  }
}
